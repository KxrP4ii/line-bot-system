<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Storage Cleanup</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>

  <style>
    :root{
      --bg:#f5f7fb;
      --card:#ffffff;
      --line:#e7ebf3;
      --text:#172033;
      --muted:#6b7280;
      --shadow:0 12px 32px rgba(15,23,42,.06);
      --radius:20px;
      --sidebar:#0f172a;
      --sidebar-text:#cbd5e1;
      --sidebar-active:#ffffff;
    }

    *{ box-sizing:border-box; }

    body{
      margin:0;
      background:var(--bg);
      color:var(--text);
      font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,"Noto Sans Thai",sans-serif;
    }

    .layout{ min-height:100vh; }

    .sidebar{
      background:var(--sidebar);
      color:var(--sidebar-text);
      min-height:100vh;
      padding:24px 16px;
      position:sticky;
      top:0;
    }

    .brand{
      color:#fff;
      font-size:20px;
      font-weight:800;
      margin-bottom:24px;
    }

    .nav-link-custom{
      display:block;
      text-decoration:none;
      color:var(--sidebar-text);
      padding:12px 14px;
      border-radius:12px;
      margin-bottom:8px;
      transition:.15s ease;
      font-weight:500;
    }

    .nav-link-custom.active,
    .nav-link-custom:hover{
      background:rgba(255,255,255,.08);
      color:var(--sidebar-active);
    }

    .main{ padding:26px; }

    .topbar,
    .card-box,
    .summary-card{
      background:var(--card);
      border:1px solid var(--line);
      box-shadow:var(--shadow);
      border-radius:var(--radius);
    }

    .topbar{
      padding:20px 22px;
      margin-bottom:22px;
    }

    .page-title{
      font-size:28px;
      font-weight:800;
      margin:0;
    }

    .page-subtitle{
      color:var(--muted);
      font-size:14px;
      margin-top:6px;
    }

    .toolbar-row{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      align-items:center;
      justify-content:space-between;
    }

    .toolbar-right{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      align-items:center;
    }

    .sync-badge{
      font-size:12px;
      color:#18794E;
      background:#e8f7ec;
      border:1px solid #b7e4c7;
      padding:5px 10px;
      border-radius:999px;
      display:inline-flex;
      align-items:center;
      gap:6px;
    }

    .sync-dot{
      width:8px;
      height:8px;
      border-radius:50%;
      background:#16a34a;
      display:inline-block;
    }

    .summary-card{
      padding:18px;
      height:100%;
    }

    .summary-label{
      color:var(--muted);
      font-size:13px;
      margin-bottom:10px;
    }

    .summary-value{
      font-size:28px;
      font-weight:800;
      line-height:1;
    }

    .card-box{
      padding:18px;
      margin-bottom:22px;
    }

    .section-title{
      font-size:18px;
      font-weight:800;
      margin-bottom:4px;
    }

    .section-subtitle{
      color:var(--muted);
      font-size:13px;
      margin-bottom:14px;
    }

    .cleanup-list{
      max-height:480px;
      overflow:auto;
      border:1px solid var(--line);
      border-radius:16px;
      padding:10px 12px;
      background:#fff;
      font-size:13px;
    }

    .cleanup-row{
      padding:10px 4px;
      border-bottom:1px solid #eef2f7;
      word-break:break-word;
    }

    .cleanup-row:last-child{
      border-bottom:none;
    }

    .modal-content{
      border:none;
      border-radius:20px;
      overflow:hidden;
      box-shadow:0 20px 50px rgba(15,23,42,.16);
    }

    .modal-header{
      border-bottom:1px solid var(--line);
      padding:16px 18px;
    }

    .modal-body{
      padding:18px;
    }

    .modal-footer{
      border-top:1px solid var(--line);
      padding:14px 18px;
    }

    @media (max-width:991px){
      .sidebar{
        min-height:auto;
        position:relative;
      }

      .main{
        padding:18px;
      }
    }
  </style>
</head>

<body>
  <div class="container-fluid layout">
    <div class="row">
      <div class="col-lg-2 p-0">
        <aside class="sidebar">
          <div class="brand">Workflow System</div>

          <a href="/dashboard" class="nav-link-custom" id="dashboardMenu">Dashboard</a>
          <a href="/analytics" class="nav-link-custom" id="analyticsMenu">Analytics</a>
          <a href="/groups" class="nav-link-custom" id="groupsMenu">Groups</a>
          <a href="/users" class="nav-link-custom" id="usersMenu">Users</a>
          <a href="/logs" class="nav-link-custom" id="logsMenu">Logs</a>
          <a href="/spam" class="nav-link-custom" id="spamMenu">Spam Monitor</a>
          <a href="/cleanup" class="nav-link-custom active" id="cleanupMenu">Storage Cleanup</a>
          <a href="/support" id="supportMenu" class="nav-link-custom">Support</a>
        </aside>
      </div>

      <div class="col-lg-10">
        <main class="main">
          <div class="topbar">
            <div class="toolbar-row">
              <div>
                <h1 class="page-title">Storage Cleanup</h1>
                <div class="page-subtitle">ตรวจและลบ orphan files ใน Cloudinary ที่ไม่ได้ถูกใช้งานใน Database</div>
              </div>

              <div class="toolbar-right">
                <span class="sync-badge" id="syncStatus">
                  <span class="sync-dot"></span>
                  Realtime Sync
                </span>
                <span id="userInfo" class="badge text-bg-dark"></span>
                <button class="btn btn-outline-danger btn-sm" onclick="logout()">Logout</button>
              </div>
            </div>
          </div>

          <div class="row g-3 mb-4">
            <div class="col-md-3">
              <div class="summary-card">
                <div class="summary-label">Cloudinary Files</div>
                <div class="summary-value" id="totalCloudinaryFiles">-</div>
              </div>
            </div>

            <div class="col-md-3">
              <div class="summary-card">
                <div class="summary-label">Used in DB</div>
                <div class="summary-value" id="totalUsedInDb">-</div>
              </div>
            </div>

            <div class="col-md-3">
              <div class="summary-card">
                <div class="summary-label">Orphan Files</div>
                <div class="summary-value" id="orphanCount">-</div>
              </div>
            </div>

            <div class="col-md-3">
              <div class="summary-card">
                <div class="summary-label">Orphan Size</div>
                <div class="summary-value" id="orphanBytes">-</div>
              </div>
            </div>
          </div>

          <div class="card-box">
            <div class="toolbar-row">
              <div>
                <div class="section-title">Cleanup Control</div>
                <div class="section-subtitle">กดสแกนก่อนเพื่อดูรายการ orphan จากนั้นค่อยยืนยันลบจริง</div>
              </div>

              <div class="toolbar-right">
                <button class="btn btn-outline-primary btn-sm" onclick="scanCleanup()">สแกนก่อน</button>
                <button class="btn btn-warning btn-sm" onclick="openCleanupConfirm()">Cleanup ทันที</button>
              </div>
            </div>

            <div class="alert alert-warning mb-3">
              ระบบจะลบเฉพาะไฟล์ orphan ใน Cloudinary เท่านั้น ไม่ลบ keyword, user, logs หรือข้อมูลหลักในระบบ
            </div>

            <div class="cleanup-list" id="cleanupPreviewList">
              <div class="text-muted">ยังไม่ได้สแกนข้อมูล</div>
            </div>
          </div>
        </main>
      </div>
    </div>
  </div>

  <div class="modal fade" id="cleanupConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header bg-warning-subtle">
          <h5 class="modal-title">ยืนยัน Cleanup</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>

        <div class="modal-body">
          <div class="mb-2">ระบบจะลบเฉพาะไฟล์ orphan ใน Cloudinary เท่านั้น</div>
          <div class="text-muted small mb-3">จะไม่ลบ keyword, user หรือ log</div>

          <div class="border rounded p-3 bg-light">
            <div><strong>จำนวน orphan:</strong> <span id="cleanupConfirmCount">0</span> ไฟล์</div>
            <div><strong>ขนาดรวม:</strong> <span id="cleanupConfirmSize">0 B</span></div>
          </div>
        </div>

        <div class="modal-footer">
          <button class="btn btn-outline-secondary" data-bs-dismiss="modal">ยกเลิก</button>
          <button class="btn btn-warning" onclick="runCleanup()">ยืนยัน Cleanup</button>
        </div>
      </div>
    </div>
  </div>

  <script src="/socket.io/socket.io.js"></script>
  <script src="/js/sidebarPolicy.js"></script>

  <script>
    const token = localStorage.getItem("token")
    let user = {}
    let cleanupScanData = null
    let cleanupConfirmModal

    try {
      user = JSON.parse(localStorage.getItem("user") || "{}")
    } catch (error) {
      user = {}
    }

    initSidebarPolicy("cleanup")

    function formatBytes(bytes = 0) {
      if (!bytes) return "0 B"

      const units = ["B", "KB", "MB", "GB"]
      let value = Number(bytes || 0)
      let index = 0

      while (value >= 1024 && index < units.length - 1) {
        value /= 1024
        index++
      }

      return `${value.toFixed(value >= 10 || index === 0 ? 0 : 1)} ${units[index]}`
    }

    function escapeHtml(str) {
      return String(str || "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;")
    }

    function renderCleanupPreview(data) {
      document.getElementById("totalCloudinaryFiles").textContent = data?.totalCloudinaryFiles ?? "-"
      document.getElementById("totalUsedInDb").textContent = data?.totalUsedInDb ?? "-"
      document.getElementById("orphanCount").textContent = data?.orphanCount ?? "-"
      document.getElementById("orphanBytes").textContent = formatBytes(data?.orphanBytes || 0)

      const box = document.getElementById("cleanupPreviewList")

      if (!data || !Array.isArray(data.orphans)) {
        box.innerHTML = `<div class="text-muted">ยังไม่ได้สแกนข้อมูล</div>`
        return
      }

      if (!data.orphans.length) {
        box.innerHTML = `<div class="text-success">ไม่พบ orphan file ใน Cloudinary</div>`
        return
      }

      box.innerHTML = data.orphans.map(item => `
        <div class="cleanup-row">
          <div><strong>${escapeHtml(item.public_id)}</strong></div>
          <div class="text-muted small">
            type: ${escapeHtml(item.resource_type || "-")} |
            size: ${formatBytes(item.bytes || 0)}
          </div>
        </div>
      `).join("")
    }

    async function scanCleanup() {
      try {
        const res = await fetch("/api/cleanup/orphan-media", {
          headers: {
            Authorization: `Bearer ${token}`
          }
        })

        const data = await res.json()

        if (!res.ok) {
          alert(data.error || "สแกน cleanup ไม่สำเร็จ")
          return
        }

        cleanupScanData = data
        renderCleanupPreview(data)
      } catch (error) {
        alert("สแกน cleanup ไม่สำเร็จ")
      }
    }

    function openCleanupConfirm() {
      if (!cleanupScanData) {
        alert("กรุณาสแกนก่อน cleanup")
        return
      }

      document.getElementById("cleanupConfirmCount").textContent = cleanupScanData.orphanCount || 0
      document.getElementById("cleanupConfirmSize").textContent = formatBytes(cleanupScanData.orphanBytes || 0)

      cleanupConfirmModal.show()
    }

    async function runCleanup() {
      try {
        const res = await fetch("/api/cleanup/orphan-media", {
          method: "POST",
          headers: {
            Authorization: `Bearer ${token}`
          }
        })

        const data = await res.json()

        if (!res.ok) {
          alert(data.error || "cleanup ไม่สำเร็จ")
          return
        }

        cleanupConfirmModal.hide()
        alert(`cleanup สำเร็จ ลบ ${data.deletedCount || 0} ไฟล์`)
        await scanCleanup()
      } catch (error) {
        alert("cleanup ไม่สำเร็จ")
      }
    }

    document.addEventListener("DOMContentLoaded", () => {
      cleanupConfirmModal = new bootstrap.Modal(document.getElementById("cleanupConfirmModal"))
      scanCleanup()
    })

    const socket = io()

    socket.on("connect", () => {
      const syncStatus = document.getElementById("syncStatus")
      if (syncStatus) {
        syncStatus.innerHTML = `<span class="sync-dot"></span> Realtime Sync`
      }
    })

    socket.on("disconnect", () => {
      const syncStatus = document.getElementById("syncStatus")
      if (syncStatus) {
        syncStatus.innerHTML = `<span class="sync-dot" style="background:#dc2626;"></span> Sync Disconnected`
      }
    })

    socket.on("dashboard:refresh", () => {
      scanCleanup()
    })
  </script>
   <script src="/js/sidebarPolicy.js"></script>
    <script>
  initSidebarPolicy("cleanup")
    </script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>