<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Register User</title>
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />
  <style>
    :root{
      --bg:#f6f8fb;
      --card:#ffffff;
      --border:#e8edf3;
      --text:#1f2937;
      --muted:#6b7280;
      --shadow:0 10px 30px rgba(15,23,42,.08);
      --radius:20px;
    }

    body{
      min-height:100vh;
      background:linear-gradient(135deg,#eef4ff 0%, #f6f8fb 40%, #fdfdfd 100%);
      display:flex;
      align-items:center;
      justify-content:center;
      padding:24px;
      font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,"Noto Sans Thai",sans-serif;
      color:var(--text);
    }

    .register-card{
      width:100%;
      max-width:520px;
      background:var(--card);
      border:1px solid var(--border);
      border-radius:var(--radius);
      box-shadow:var(--shadow);
      padding:28px;
    }

    .brand{
      font-size:28px;
      font-weight:700;
      margin-bottom:4px;
    }

    .subtitle{
      color:var(--muted);
      font-size:14px;
      margin-bottom:24px;
    }

    .form-label{
      font-weight:600;
      margin-bottom:8px;
    }

    .form-control,
    .form-select{
      border-radius:12px;
      padding:12px 14px;
    }

    .btn{
      border-radius:12px;
      padding:11px 16px;
      font-weight:600;
    }
  </style>
</head>
<body>
  <div class="register-card">
    <div class="brand">เพิ่มสมาชิกใหม่</div>
    <div class="subtitle">Approver เท่านั้นที่สามารถสร้างผู้ใช้งานได้</div>

    <div id="registerError" class="alert alert-danger d-none"></div>
    <div id="registerSuccess" class="alert alert-success d-none"></div>

    <form id="registerForm">
      <div class="mb-3">
        <label class="form-label">Username</label>
        <input type="text" id="username" class="form-control" required />
      </div>

      <div class="mb-3">
        <label class="form-label">Password</label>
        <input type="password" id="password" class="form-control" required />
      </div>

      <div class="mb-3">
        <label class="form-label">ตำแหน่ง</label>
        <select id="role" class="form-select" required>
          <option value="editor">ผู้กรอกข้อมูล</option>
          <option value="approver">ผู้กดยืนยัน</option>
        </select>
      </div>

      <div class="d-flex gap-2 flex-wrap">
        <button type="submit" class="btn btn-primary" id="registerBtn">สร้างผู้ใช้</button>
        <a href="/users" class="btn btn-outline-secondary">กลับไปหน้า Users</a>
      </div>
    </form>
  </div>

  <script>
    const token = localStorage.getItem("token")
    let user = {}

    try {
      user = JSON.parse(localStorage.getItem("user") || "{}")
    } catch (error) {
      user = {}
    }

    if (!token || !user || user.role !== "approver") {
      localStorage.removeItem("token")
      localStorage.removeItem("user")
      window.location.replace("/login")
    }

    function showError(message = "") {
      const box = document.getElementById("registerError")
      if (!message) {
        box.classList.add("d-none")
        box.textContent = ""
        return
      }
      box.classList.remove("d-none")
      box.textContent = message
    }

    function showSuccess(message = "") {
      const box = document.getElementById("registerSuccess")
      if (!message) {
        box.classList.add("d-none")
        box.textContent = ""
        return
      }
      box.classList.remove("d-none")
      box.textContent = message
    }

    document.getElementById("registerForm").addEventListener("submit", async (e) => {
      e.preventDefault()

      showError("")
      showSuccess("")

      const btn = document.getElementById("registerBtn")
      btn.disabled = true
      btn.textContent = "กำลังสร้าง..."

      const username = document.getElementById("username").value.trim()
      const password = document.getElementById("password").value
      const role = document.getElementById("role").value

      try {
        const res = await fetch("/api/auth/register", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Authorization: `Bearer ${token}`
          },
          body: JSON.stringify({ username, password, role })
        })

        const data = await res.json()

        if (res.status === 401 || res.status === 403) {
          localStorage.removeItem("token")
          localStorage.removeItem("user")
          window.location.replace("/login")
          return
        }

        if (!res.ok) {
          showError(data.error || "สร้างผู้ใช้ไม่สำเร็จ")
          return
        }

        document.getElementById("username").value = ""
        document.getElementById("password").value = ""
        document.getElementById("role").value = "editor"

        showSuccess("สร้างผู้ใช้สำเร็จ")
      } catch (error) {
        showError("ไม่สามารถเชื่อมต่อระบบได้")
      } finally {
        btn.disabled = false
        btn.textContent = "สร้างผู้ใช้"
      }
    })
  </script>
</body>
</html>