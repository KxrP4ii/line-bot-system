<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Analytics</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <style>
    :root{
      --bg:#f5f7fb; --card:#ffffff; --line:#e7ebf3; --text:#172033; --muted:#6b7280;
      --primary:#1f3a8a; --primary-soft:#eef3ff; --shadow:0 12px 32px rgba(15,23,42,.06);
      --radius:20px; --sidebar:#0f172a; --sidebar-text:#cbd5e1; --sidebar-active:#ffffff;
    }
    *{ box-sizing:border-box; }
    body{ margin:0; background:var(--bg); color:var(--text); font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,"Noto Sans Thai",sans-serif; }
    .layout{ min-height:100vh; }
    .sidebar{ background:var(--sidebar); color:var(--sidebar-text); min-height:100vh; padding:24px 16px; position:sticky; top:0; }
    .brand{ color:#fff; font-size:20px; font-weight:800; margin-bottom:24px; }
    .nav-link-custom{ display:block; text-decoration:none; color:var(--sidebar-text); padding:12px 14px; border-radius:12px; margin-bottom:8px; transition:.15s ease; font-weight:500; }
    .nav-link-custom.active,.nav-link-custom:hover{ background:rgba(255,255,255,.08); color:var(--sidebar-active); }
    .main{ padding:26px; }
    .topbar,.card-box,.summary-card{ background:var(--card); border:1px solid var(--line); box-shadow:var(--shadow); border-radius:var(--radius); }
    .topbar{ padding:20px 22px; margin-bottom:22px; }
    .page-title{ font-size:28px; font-weight:800; margin:0; }
    .page-subtitle{ color:var(--muted); font-size:14px; margin-top:6px; }
    .toolbar-row{ display:flex; gap:10px; flex-wrap:wrap; align-items:center; justify-content:space-between; }
    .toolbar-right{ display:flex; gap:10px; flex-wrap:wrap; align-items:center; }
    .sync-badge{ font-size:12px; color:#18794E; background:#e8f7ec; border:1px solid #b7e4c7; padding:5px 10px; border-radius:999px; display:inline-flex; align-items:center; gap:6px; }
    .sync-dot{ width:8px; height:8px; border-radius:50%; background:#16a34a; display:inline-block; }
    .card-box{ padding:18px; margin-bottom:22px; }
    .summary-card{ padding:16px; height:100%; }
    .summary-label{ color:var(--muted); font-size:13px; margin-bottom:10px; }
    .summary-value{ font-size:28px; font-weight:800; line-height:1; }
    .section-title{ font-weight:800; font-size:18px; margin-bottom:4px; }
    .section-sub{ color:var(--muted); font-size:13px; }
    .chart-box{ position:relative; height:320px; margin-top:10px; }
    .list-box{ max-height:320px; overflow:auto; border:1px solid var(--line); border-radius:16px; background:#fff; margin-top:12px; }
    .list-row{ padding:12px 14px; border-bottom:1px solid #eef2f7; cursor:pointer; transition:.15s ease; display:flex; align-items:center; justify-content:space-between; gap:10px; }
    .list-row:last-child{ border-bottom:none; }
    .list-row:hover{ background:#eef3ff; }
    .badge-soft{ background:var(--primary-soft); color:var(--primary); border:1px solid #dbe5ff; border-radius:999px; padding:6px 10px; font-size:12px; font-weight:700; }
    .table-wrap{ border:1px solid var(--line); border-radius:16px; overflow:auto; max-height:420px; background:#fff; margin-top:12px; }
    .table{ margin-bottom:0; vertical-align:middle; }
    .table thead th{ position:sticky; top:0; z-index:2; background:#f8fafc; white-space:nowrap; font-size:13px; color:#4b5563; border-bottom:1px solid var(--line); }
    .modal-content{ border:none; border-radius:20px; overflow:hidden; box-shadow:0 20px 50px rgba(15,23,42,.16); }
    .modal-header{ border-bottom:1px solid var(--line); padding:16px 18px; }
    .modal-body{ padding:18px; }
    .keyword-detail-row{ display:flex; align-items:center; justify-content:space-between; gap:12px; padding:10px 0; border-bottom:1px solid #eef2f7; }
    .keyword-detail-row:last-child{ border-bottom:none; }
  </style>
</head>

<body>
  <div class="container-fluid layout">
    <div class="row">
      <div class="col-lg-2 p-0">
        <aside class="sidebar">
          <div class="brand">Workflow System</div>

          <a href="/dashboard" class="nav-link-custom" id="dashboardMenu">Dashboard</a>
          <a href="/analytics" class="nav-link-custom" id="analyticsMenu">Analytics</a>
          <a href="/groups" class="nav-link-custom" id="groupsMenu">Groups</a>
          <a href="/users" class="nav-link-custom" id="usersMenu">Users</a>
          <a href="/logs" class="nav-link-custom" id="logsMenu">Logs</a>
          <a href="/spam" class="nav-link-custom" id="spamMenu">Spam Monitor</a>
          <a href="/cleanup" class="nav-link-custom" id="cleanupMenu">Storage Cleanup</a>
          <a href="/support" id="supportMenu" class="nav-link-custom">Support</a>
        </aside>
      </div>

      <div class="col-lg-10">
        <main class="main">
          <div class="topbar">
            <div class="toolbar-row">
              <div>
                <h1 class="page-title">Group Analytics</h1>
                <div class="page-subtitle">วิเคราะห์การใช้งานบอทแยกตามกลุ่ม คีย์เวิร์ด และแนวโน้มรายวัน</div>
              </div>

              <div class="toolbar-right">
                <span class="sync-badge" id="syncStatus"><span class="sync-dot"></span> Realtime Sync</span>
                <span id="userInfo" class="badge text-bg-dark"></span>
                <button class="btn btn-outline-danger btn-sm" onclick="logout()">Logout</button>
              </div>
            </div>
          </div>

          <div class="card-box">
            <div class="toolbar-row">
              <div>
                <div class="section-title">ช่วงเวลาที่ต้องการดู</div>
                <div class="section-sub">เลือกช่วงวันเพื่ออัปเดตกราฟและอันดับการใช้งาน</div>
              </div>

              <div class="toolbar-right">
                <button class="btn btn-success btn-sm" onclick="exportExcel()">Export Excel</button>
                <button class="btn btn-outline-primary btn-sm" onclick="setDaysAndLoad(7)">7 วัน</button>
                <button class="btn btn-outline-primary btn-sm" onclick="setDaysAndLoad(30)">30 วัน</button>
                <button class="btn btn-outline-primary btn-sm" onclick="setDaysAndLoad(90)">90 วัน</button>
              </div>
            </div>
          </div>

          <div class="row g-3 mb-3">
            <div class="col-md-4">
              <div class="summary-card">
                <div class="summary-label">Total Usage</div>
                <div id="totalUsage" class="summary-value">0</div>
              </div>
            </div>

            <div class="col-md-4">
              <div class="summary-card">
                <div class="summary-label">Groups</div>
                <div id="totalGroups" class="summary-value">0</div>
              </div>
            </div>

            <div class="col-md-4">
              <div class="summary-card">
                <div class="summary-label">Keywords</div>
                <div id="totalKeywords" class="summary-value">0</div>
              </div>
            </div>
          </div>

          <div class="card-box">
            <div class="section-title">Daily Usage</div>
            <div class="section-sub">จำนวนการใช้งาน keyword รายวัน</div>
            <div class="chart-box"><canvas id="dailyChart"></canvas></div>
          </div>

          <div class="row g-3">
            <div class="col-md-6">
              <div class="card-box">
                <div class="section-title">Top Keywords</div>
                <div class="section-sub">คำสั่งที่ถูกเรียกใช้งานบ่อยที่สุด</div>
                <div class="chart-box"><canvas id="keywordChart"></canvas></div>
              </div>
            </div>

            <div class="col-md-6">
              <div class="card-box">
                <div class="section-title">Top Groups</div>
                <div class="section-sub">กลุ่มที่ใช้งานบอทมากที่สุด</div>
                <div class="chart-box"><canvas id="groupChart"></canvas></div>
              </div>
            </div>
          </div>

          <div class="row g-3">
            <div class="col-md-6">
              <div class="card-box">
                <div class="section-title">Top Groups</div>
                <div class="section-sub">คลิกชื่อกลุ่มเพื่อดู keyword ที่ถูกใช้บ่อยในกลุ่มนั้น</div>
                <div id="groupList" class="list-box"></div>
              </div>
            </div>

            <div class="col-md-6">
              <div class="card-box">
                <div class="section-title">Top Keywords</div>
                <div class="section-sub">อันดับ keyword ที่ถูกใช้งานมากที่สุด</div>
                <div id="keywordList" class="list-box"></div>
              </div>
            </div>
          </div>

          <div class="card-box">
            <div class="section-title">Group / Keyword Usage Table</div>

            <div class="table-wrap">
              <table class="table align-middle">
                <thead>
                  <tr>
                    <th>Group</th>
                    <th>Group ID</th>
                    <th>Keyword</th>
                    <th>Total</th>
                  </tr>
                </thead>
                <tbody id="usageTableBody"></tbody>
              </table>
            </div>
          </div>
        </main>
      </div>
    </div>
  </div>

  <div class="modal fade" id="groupModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
      <div class="modal-content">
        <div class="modal-header">
          <h5 id="groupTitle" class="mb-0">รายละเอียดกลุ่ม</h5>
          <button class="btn-close" data-bs-dismiss="modal"></button>
        </div>

        <div class="modal-body">
          <div id="groupDetail"></div>
        </div>
      </div>
    </div>
  </div>

  <script src="/socket.io/socket.io.js"></script>
  <script src="/js/sidebarPolicy.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    const token = localStorage.getItem("token")
    let user = {}
    let dailyChart = null
    let keywordChart = null
    let groupChart = null
    let currentDays = 30

    try {
      user = JSON.parse(localStorage.getItem("user") || "{}")
    } catch (error) {
      user = {}
    }

    if (!token || !user || !["approver", "superadmin"].includes(user.role)) {
      localStorage.clear()
      window.location.replace("/login")
    }

    initSidebarPolicy("analytics")

    function logout() {
      localStorage.clear()
      window.location.replace("/login")
    }

    async function exportExcel() {
      try {
        const days = currentDays || 30

        const res = await fetch(`/api/analytics/export?days=${days}`, {
          method: "GET",
          headers: {
            Authorization: `Bearer ${token}`
          }
        })

        if (!res.ok) {
          let errorMessage = "Export Excel ไม่สำเร็จ"

          try {
            const data = await res.json()
            errorMessage = data.error || errorMessage
          } catch (error) {}

          alert(errorMessage)
          return
        }

        const blob = await res.blob()
        const url = window.URL.createObjectURL(blob)

        const a = document.createElement("a")
        a.href = url
        a.download = `analytics_${days}days.xlsx`
        document.body.appendChild(a)
        a.click()

        a.remove()
        window.URL.revokeObjectURL(url)
      } catch (error) {
        alert("Export Excel ไม่สำเร็จ")
      }
    }

    function destroyCharts() {
      if (dailyChart) {
        dailyChart.destroy()
        dailyChart = null
      }

      if (keywordChart) {
        keywordChart.destroy()
        keywordChart = null
      }

      if (groupChart) {
        groupChart.destroy()
        groupChart = null
      }
    }

    function setDaysAndLoad(days) {
      currentDays = days
      loadAll()
    }

    async function loadAll() {
      await loadCharts(currentDays)
      await loadLists(currentDays)
      await loadUsageTable(currentDays)
    }

    async function loadCharts(days) {
      try {
        const res = await fetch(`/api/analytics/charts?days=${days}`, {
          headers: { Authorization: `Bearer ${token}` }
        })

        const data = await res.json()

        if (!res.ok) {
          alert(data.error || "โหลด charts ไม่สำเร็จ")
          return
        }

        document.getElementById("totalUsage").innerText = data.totalUsage || 0
        document.getElementById("totalGroups").innerText = data.totalGroups || 0
        document.getElementById("totalKeywords").innerText = data.totalKeywords || 0

        destroyCharts()

        dailyChart = new Chart(document.getElementById("dailyChart"), {
          type: "line",
          data: {
            labels: (data.dailyUsage || []).map(i => i.date),
            datasets: [
              {
                label: "Usage",
                data: (data.dailyUsage || []).map(i => i.total),
                tension: 0.25,
                fill: false
              }
            ]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false
          }
        })

        keywordChart = new Chart(document.getElementById("keywordChart"), {
          type: "bar",
          data: {
            labels: (data.topKeywordsChart || []).map(i => i.keyword),
            datasets: [
              {
                label: "Usage",
                data: (data.topKeywordsChart || []).map(i => i.total)
              }
            ]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false
          }
        })

        groupChart = new Chart(document.getElementById("groupChart"), {
          type: "bar",
          data: {
            labels: (data.topGroupsChart || []).map(i => i.groupName || i.groupId),
            datasets: [
              {
                label: "Usage",
                data: (data.topGroupsChart || []).map(i => i.total)
              }
            ]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            indexAxis: "y"
          }
        })
      } catch (error) {
        alert("โหลด charts ไม่สำเร็จ")
      }
    }

    async function loadLists(days) {
      try {
        const res = await fetch(`/api/analytics/summary?days=${days}`, {
          headers: { Authorization: `Bearer ${token}` }
        })

        const data = await res.json()

        if (!res.ok) return

        document.getElementById("groupList").innerHTML = (data.topGroups || []).map(g => {
          const safeGroupId = String(g.groupId || "").replace(/'/g, "\\'")
          const safeGroupName = String(g.groupName || g.groupId || "-").replace(/'/g, "\\'")

          return `
            <div class="list-row" onclick="openGroup('${safeGroupId}','${safeGroupName}')">
              <div>${g.groupName || g.groupId || "-"}</div>
              <span class="badge-soft">${g.total || 0}</span>
            </div>
          `
        }).join("")

        document.getElementById("keywordList").innerHTML = (data.topKeywords || []).map(k => `
          <div class="list-row" style="cursor:default">
            <div>${k.keyword || "-"}</div>
            <span class="badge-soft">${k.total || 0}</span>
          </div>
        `).join("")
      } catch (error) {
        console.error("loadLists error:", error)
      }
    }

    async function loadUsageTable(days) {
      try {
        const res = await fetch(`/api/analytics/group-usage-table?days=${days}`, {
          headers: { Authorization: `Bearer ${token}` }
        })

        const data = await res.json()

        if (!res.ok) return

        const tbody = document.getElementById("usageTableBody")

        if (!Array.isArray(data) || !data.length) {
          tbody.innerHTML = `<tr><td colspan="4" class="text-center text-muted py-4">ยังไม่มีข้อมูล usage</td></tr>`
          return
        }

        tbody.innerHTML = data.map(row => `
          <tr>
            <td>${row.groupName || "-"}</td>
            <td>${row.groupId || "-"}</td>
            <td>${row.keyword || "-"}</td>
            <td>${row.total || 0}</td>
          </tr>
        `).join("")
      } catch (error) {
        console.error("loadUsageTable error:", error)
      }
    }

    async function openGroup(id, name) {
      try {
        document.getElementById("groupTitle").innerText = name || "รายละเอียดกลุ่ม"

        const res = await fetch(`/api/analytics/group/${id}?days=${currentDays}`, {
          headers: { Authorization: `Bearer ${token}` }
        })

        const data = await res.json()

        document.getElementById("groupDetail").innerHTML = Array.isArray(data) && data.length
          ? data.map(i => `
              <div class="keyword-detail-row">
                <div>${i.keyword || "-"}</div>
                <span class="badge-soft">${i.total || 0}</span>
              </div>
            `).join("")
          : `<div class="text-muted">ยังไม่มีข้อมูล</div>`

        new bootstrap.Modal(document.getElementById("groupModal")).show()
      } catch (error) {
        alert("โหลดรายละเอียดกลุ่มไม่สำเร็จ")
      }
    }

    const socket = io()

    socket.on("connect", () => {
      document.getElementById("syncStatus").innerHTML = `<span class="sync-dot"></span> Realtime Sync`
    })

    socket.on("disconnect", () => {
      document.getElementById("syncStatus").innerHTML = `<span class="sync-dot" style="background:#dc2626;"></span> Sync Disconnected`
    })

    socket.on("dashboard:refresh", () => {
      loadAll()
    })

    loadAll()
  </script>
</body>
</html>