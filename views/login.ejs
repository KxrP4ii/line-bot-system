<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Login</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <style>
    :root{
      --bg:#081026;
      --text:#f8fafc;
      --muted:#94a3b8;
      --accent:#38bdf8;
      --shadow:0 24px 60px rgba(15,23,42,.35);
      --radius:24px;
    }

    *{ box-sizing:border-box; }

    body{
      min-height:100vh;
      margin:0;
      background:radial-gradient(circle at top left, rgba(56,189,248,.18), transparent 25%),
        radial-gradient(circle at bottom right, rgba(99,102,241,.14), transparent 20%),
        linear-gradient(160deg, #020617 0%, #081026 40%, #111827 100%);
      display:flex;
      align-items:center;
      justify-content:center;
      padding:24px;
      font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,"Noto Sans Thai",sans-serif;
      color:var(--text);
      overflow-x:hidden;
    }

    body::before{
      content:"";
      position:fixed;
      inset:0;
      z-index:-2;
      background-image:
        radial-gradient(circle at 20% 20%, rgba(56,189,248,.18), transparent 22%),
        linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px),
        linear-gradient(0deg, rgba(255,255,255,.04) 1px, transparent 1px);
      background-size:160px 160px, 40px 40px, 40px 40px;
      pointer-events:none;
      opacity:.35;
    }

    body::after{
      content:"";
      position:fixed;
      inset:0;
      z-index:-1;
      pointer-events:none;
      opacity:.24;
      animation:scanLine 6s linear infinite;
      background-image:
        repeating-linear-gradient(180deg, rgba(255,255,255,.00) 0, rgba(255,255,255,.05) 1px, rgba(255,255,255,.00) 2px),
        radial-gradient(circle at 50% 12%, rgba(56,189,248,.12), transparent 18%);
      background-repeat:no-repeat;
      background-position:center 18%;
      background-size:520px 520px;
    }

    .login-card{
      position:relative;
      width:100%;
      max-width:420px;
      background:rgba(8,14,38,.96);
      border:1px solid rgba(56,189,248,.24);
      border-radius:var(--radius);
      box-shadow:var(--shadow);
      padding:32px;
      overflow:hidden;
      background-image:
        radial-gradient(circle at top left, rgba(56,189,248,.08), transparent 25%),
        radial-gradient(circle at bottom right, rgba(124,58,237,.08), transparent 24%);
    }

    .login-card::before,
    .login-card::after{
      content:"";
      position:absolute;
      border-radius:50%;
      filter:blur(36px);
      opacity:.55;
      pointer-events:none;
    }

    .login-card::before{
      width:180px;
      height:180px;
      top:24px;
      right:-40px;
      background:rgba(56,189,248,.18);
    }

    .login-card::after{
      width:140px;
      height:140px;
      bottom:-30px;
      left:-30px;
      background:rgba(99,102,241,.18);
      opacity:.45;
    }

    .login-head{
      display:flex;
      align-items:center;
      gap:16px;
      margin-bottom:20px;
      position:relative;
      z-index:1;
    }

    .robot-icon{
      width:64px;
      height:64px;
      display:flex;
      align-items:center;
      justify-content:center;
      border-radius:18px;
      background:linear-gradient(135deg,#38bdf8,#8b5cf6);
      color:#fff;
      font-size:30px;
      box-shadow:0 18px 36px rgba(56,189,248,.24);
      animation:pulseGlow 3s ease-in-out infinite;
    }

    .brand{
      font-size:30px;
      font-weight:800;
      letter-spacing:.06em;
      margin:0;
      text-transform:uppercase;
      text-shadow:0 2px 14px rgba(56,189,248,.18);
    }

    .subtitle{
      color:var(--muted);
      font-size:13px;
      margin-top:6px;
      line-height:1.4;
      letter-spacing:.04em;
    }

    @keyframes pulseGlow{
      0%,100%{ transform:scale(1); box-shadow:0 18px 36px rgba(56,189,248,.24); }
      50%{ transform:scale(1.03); box-shadow:0 28px 48px rgba(56,189,248,.32); }
    }

    @keyframes scanLine{
      0%{ transform:translateY(0); }
      100%{ transform:translateY(240px); }
    }

    .form-label{
      font-weight:700;
      margin-bottom:8px;
      color:#e2e8f0;
      letter-spacing:.02em;
    }

    .input-field{ margin-top:18px; }

    .form-control{
      position:relative;
      z-index:1;
      width:100%;
      border-radius:20px;
      padding:14px 16px;
      border:1px solid rgba(56,189,248,.35);
      background:rgba(10,16,36,.97);
      color:#ffffff !important;
      font-weight:600;
      transition:.25s ease;
      box-shadow:inset 0 10px 30px rgba(4,8,18,.45);
      caret-color:#38bdf8;
    }

    .form-control::placeholder{
      color:rgba(248,250,252,.72);
      opacity:1;
    }

    .form-control:focus{
      border-color:#38bdf8;
      box-shadow:0 0 0 5px rgba(56,189,248,.18);
      outline:none;
      background:rgba(8,14,32,.98);
    }

    .btn{
      border-radius:18px;
      padding:14px 18px;
      font-weight:700;
      text-transform:uppercase;
      letter-spacing:.08em;
      transition:.25s ease;
    }

    .btn-primary{
      background:linear-gradient(135deg,#38bdf8,#7c3aed);
      border:1px solid rgba(255,255,255,.14);
      box-shadow:0 18px 35px rgba(56,189,248,.22);
    }

    .btn-primary:hover{
      transform:translateY(-1px);
      background:linear-gradient(135deg,#22d3ee,#7c3aed);
    }

    .btn-register{
      background:rgba(255,255,255,.06);
      border:1px solid rgba(56,189,248,.35);
      color:#e0f2fe;
      text-decoration:none;
      display:block;
      text-align:center;
    }

    .btn-register:hover{
      background:rgba(56,189,248,.14);
      color:#ffffff;
      transform:translateY(-1px);
    }

    .register-status{
      margin-top:14px;
      padding:12px 14px;
      border-radius:16px;
      background:rgba(255,255,255,.04);
      border:1px solid rgba(148,163,184,.16);
      color:#cbd5e1;
      font-size:13px;
      line-height:1.5;
      text-align:center;
    }

    .register-open{
      border-color:rgba(52,211,153,.35);
      color:#bbf7d0;
    }

    .register-closed{
      border-color:rgba(248,113,113,.35);
      color:#fecaca;
    }

    .alert{
      border-radius:14px;
      border:1px solid rgba(248,113,113,.35);
      background:rgba(248,113,113,.12);
      color:#fee2e2;
    }
  </style>
</head>
<body>
  <div class="login-card">
    <div class="login-head">
      <div class="robot-icon">🤖</div>
      <div>
        <div class="brand">เข้าสู่ระบบ</div>
        <div class="subtitle">ยินดีต้อนรับสู่ Workflow AI Command Center</div>
      </div>
    </div>

    <div id="loginError" class="alert alert-danger d-none"></div>

    <form id="loginForm">
      <div class="mb-3 input-field">
        <label class="form-label" for="username">Username</label>
        <input type="text" id="username" class="form-control" placeholder="Enter your username" required />
      </div>

      <div class="mb-3 input-field">
        <label class="form-label" for="password">Password</label>
        <input type="password" id="password" class="form-control" placeholder="Enter your password" required />
      </div>

      <div class="d-grid">
        <button type="submit" class="btn btn-primary" id="loginBtn">Login</button>
      </div>
    </form>

    <div id="registerBox" class="d-grid mt-3 d-none">
      <a href="/register" class="btn btn-register">สมัครสมาชิก</a>
    </div>

    <div id="registerStatus" class="register-status d-none"></div>
  </div>

  <script>
    function showError(message = "") {
      const box = document.getElementById("loginError")
      if (!message) {
        box.classList.add("d-none")
        box.textContent = ""
        return
      }
      box.classList.remove("d-none")
      box.textContent = message
    }

    function hasValidSession() {
      const token = localStorage.getItem("token")
      const userRaw = localStorage.getItem("user")

      if (!token || !userRaw) return false

      try {
        const user = JSON.parse(userRaw)
        return !!(user && (user.username || user.id || user.role))
      } catch (error) {
        return false
      }
    }

    async function loadRegisterStatus() {
      const registerBox = document.getElementById("registerBox")
      const registerStatus = document.getElementById("registerStatus")

      try {
        const res = await fetch("/api/settings/register")
        const data = await res.json()

        registerStatus.classList.remove("d-none", "register-open", "register-closed")

        if (!res.ok) {
          registerBox.classList.add("d-none")
          registerStatus.classList.add("register-closed")
          registerStatus.textContent = "ไม่สามารถตรวจสอบสถานะการสมัครได้"
          return
        }

        if (data.registerEnabled === true) {
          registerBox.classList.remove("d-none")
          registerStatus.classList.add("register-open")
          registerStatus.textContent = "ระบบเปิดรับสมัครสมาชิกอยู่"
        } else {
          registerBox.classList.add("d-none")
          registerStatus.classList.add("register-closed")
          registerStatus.textContent = "ระบบปิดรับสมัครสมาชิกชั่วคราว"
        }
      } catch (error) {
        registerBox.classList.add("d-none")
        registerStatus.classList.remove("d-none", "register-open")
        registerStatus.classList.add("register-closed")
        registerStatus.textContent = "ไม่สามารถเชื่อมต่อระบบเพื่อตรวจสอบสถานะการสมัครได้"
      }
    }

    document.addEventListener("DOMContentLoaded", () => {
      if (hasValidSession()) {
        window.location.replace("/dashboard")
        return
      }

      loadRegisterStatus()
    })

    document.getElementById("loginForm").addEventListener("submit", async (e) => {
      e.preventDefault()
      showError("")

      const btn = document.getElementById("loginBtn")
      btn.disabled = true
      btn.textContent = "กำลังเข้าสู่ระบบ..."

      const username = document.getElementById("username").value.trim()
      const password = document.getElementById("password").value

      try {
        const res = await fetch("/api/auth/login", {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify({ username, password })
        })

        const data = await res.json()

        if (!res.ok) {
          showError(data.error || "Login failed")
          return
        }

        if (!data.token || !data.user) {
          showError("ข้อมูลตอบกลับจากระบบไม่ถูกต้อง")
          return
        }

        localStorage.setItem("token", data.token)
        localStorage.setItem("user", JSON.stringify(data.user))

        window.location.replace("/dashboard")
      } catch (error) {
        showError("ไม่สามารถเชื่อมต่อระบบได้")
      } finally {
        btn.disabled = false
        btn.textContent = "Login"
      }
    })
  </script>
</body>
</html>