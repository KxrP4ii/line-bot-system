<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Groups</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <style>
    :root{
      --bg:#f5f7fb; --card:#ffffff; --line:#e7ebf3; --text:#172033; --muted:#6b7280;
      --shadow:0 12px 32px rgba(15,23,42,.06); --radius:20px; --sidebar:#0f172a;
      --sidebar-text:#cbd5e1; --sidebar-active:#ffffff;
    }
    *{ box-sizing:border-box; }
    body{ margin:0; background:var(--bg); color:var(--text); font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,"Noto Sans Thai",sans-serif; }
    .layout{ min-height:100vh; }
    .sidebar{ background:var(--sidebar); color:var(--sidebar-text); min-height:100vh; padding:24px 16px; position:sticky; top:0; }
    .brand{ color:#fff; font-size:20px; font-weight:800; margin-bottom:24px; }
    .nav-link-custom{ display:block; text-decoration:none; color:var(--sidebar-text); padding:12px 14px; border-radius:12px; margin-bottom:8px; transition:.15s ease; font-weight:500; }
    .nav-link-custom.active,.nav-link-custom:hover{ background:rgba(255,255,255,.08); color:var(--sidebar-active); }
    .main{ padding:26px; }
    .topbar,.card-box{ background:var(--card); border:1px solid var(--line); box-shadow:var(--shadow); border-radius:var(--radius); }
    .topbar{ padding:20px 22px; margin-bottom:22px; }
    .page-title{ font-size:28px; font-weight:800; margin:0; }
    .page-subtitle{ color:var(--muted); font-size:14px; margin-top:6px; }
    .toolbar-row{ display:flex; gap:10px; flex-wrap:wrap; align-items:center; justify-content:space-between; }
    .toolbar-right{ display:flex; gap:10px; flex-wrap:wrap; align-items:center; }
    .sync-badge{ font-size:12px; color:#18794E; background:#e8f7ec; border:1px solid #b7e4c7; padding:5px 10px; border-radius:999px; display:inline-flex; align-items:center; gap:6px; }
    .sync-dot{ width:8px; height:8px; border-radius:50%; background:#16a34a; display:inline-block; }
    .card-box{ padding:18px; margin-bottom:22px; }
    .table-wrap{ border:1px solid var(--line); border-radius:16px; overflow:auto; max-height:680px; background:#fff; }
    .table{ margin-bottom:0; vertical-align:middle; }
    .table thead th{ position:sticky; top:0; z-index:2; background:#f8fafc; white-space:nowrap; font-size:13px; color:#4b5563; border-bottom:1px solid var(--line); }
    .status-pill{ display:inline-flex; align-items:center; justify-content:center; min-width:90px; border-radius:999px; padding:6px 10px; font-size:12px; font-weight:700; }
    .status-active{ background:#e8f7ec; color:#18794E; border:1px solid #b7e4c7; }
    .status-inactive{ background:#fdecec; color:#B42318; border:1px solid #f5b5b0; }
    .modal-content{ border:none; border-radius:20px; overflow:hidden; box-shadow:0 20px 50px rgba(15,23,42,.16); }
    .modal-header{ border-bottom:1px solid var(--line); padding:16px 18px; }
    .modal-body{ padding:18px; }
    .modal-footer{ border-top:1px solid var(--line); padding:14px 18px; }
  </style>
</head>
<body>
  <div class="container-fluid layout">
    <div class="row">
      <div class="col-lg-2 p-0">
        <aside class="sidebar">
  <div class="brand">Workflow System</div>

  <a href="/dashboard" class="nav-link-custom" id="dashboardMenu">Dashboard</a>
  <a href="/analytics" class="nav-link-custom" id="analyticsMenu">Analytics</a>
  <a href="/groups" class="nav-link-custom" id="groupsMenu">Groups</a>
  <a href="/users" class="nav-link-custom" id="usersMenu">Users</a>
  <a href="/logs" class="nav-link-custom" id="logsMenu">Logs</a>
  <a href="/spam" class="nav-link-custom" id="spamMenu">Spam Monitor</a>
  <a href="/cleanup" class="nav-link-custom" id="cleanupMenu">Storage Cleanup</a>
  <a href="/support" id="supportMenu" class="nav-link-custom">Support</a>
    </aside>
      </div>

      <div class="col-lg-10">
        <main class="main">
          <div class="topbar">
            <div class="toolbar-row">
              <div>
                <h1 class="page-title">Groups</h1>
                <div class="page-subtitle">กลุ่มจะถูกเพิ่มเข้าระบบอัตโนมัติเมื่อ bot เห็นข้อความในกลุ่มนั้น</div>
              </div>
              <div class="toolbar-right">
                <span class="sync-badge" id="syncStatus"><span class="sync-dot"></span> Realtime Sync</span>
                <span id="userInfo" class="badge text-bg-dark"></span>
                <button id="createGroupBtn" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#groupModal">+ เพิ่มกลุ่มเอง</button>
                <button class="btn btn-outline-danger btn-sm" onclick="logout()">Logout</button>
              </div>
            </div>
          </div>

          <div class="card-box">
            <div class="toolbar-row">
              <input type="text" id="searchGroupInput" class="form-control" placeholder="ค้นหา groupId หรือชื่อกลุ่ม" oninput="applyGroupFilter()" style="min-width:320px" />
            </div>

            <div class="table-wrap">
              <table class="table align-middle">
                <thead>
                  <tr>
                    <th>Group Name</th>
                    <th>Group ID</th>
                    <th>Status</th>
                    <th>Last Seen</th>
                    <th>จัดการ</th>
                  </tr>
                </thead>
                <tbody id="groupTableBody"></tbody>
              </table>
            </div>
          </div>
        </main>
      </div>
    </div>
  </div>

  <div class="modal fade" id="groupModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">เพิ่ม / แก้ไขกลุ่ม</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <form id="groupForm">
            <input type="hidden" id="editGroupId" />
            <div class="mb-3">
              <label class="form-label">Group ID</label>
              <input type="text" id="groupId" class="form-control" required />
            </div>
            <div class="mb-3">
              <label class="form-label">Group Name</label>
              <input type="text" id="groupName" class="form-control" />
            </div>
            <div class="mb-0">
              <label class="form-label">Status</label>
              <select id="isActive" class="form-select">
                <option value="true">active</option>
                <option value="false">inactive</option>
              </select>
            </div>
          </form>
        </div>
        <div class="modal-footer">
          <button class="btn btn-outline-secondary" type="button" onclick="resetGroupForm()">ล้างฟอร์ม</button>
          <button class="btn btn-primary" type="submit" form="groupForm">บันทึก</button>
        </div>
      </div>
    </div>
  </div>

  <script src="/socket.io/socket.io.js"></script>
  <script>
    const token = localStorage.getItem("token")
    let user = {}
    let allGroups = []
    let groupModal
    let isRealtimeLoading = false

    try {
      user = JSON.parse(localStorage.getItem("user") || "{}")
    } catch (error) {
      user = {}
    }

    if (!token || !user || !["approver","superadmin"].includes(user.role)) {
      localStorage.clear()
      window.location.replace("/login")
    }

    const isSuper = user.role === "superadmin"
    const isApprover = user.role === "approver"

    document.getElementById("userInfo").textContent = `${user.username || ""} (${user.role || ""})`

    function logout() {
      localStorage.clear()
      window.location.replace("/login")
    }

    function applyRoleVisibility() {
      document.getElementById("analyticsMenu").style.display = "block"
      document.getElementById("groupsMenu").style.display = "block"
      document.getElementById("logsMenu").style.display = "block"
      document.getElementById("usersMenu").style.display = "block"

      if (!isSuper) {
        document.getElementById("createGroupBtn").style.display = "none"
      }
    }

    function formatDateTime(value) {
      if (!value) return "-"
      return new Date(value).toLocaleString()
    }

    function statusBadge(isActive) {
      return isActive
        ? `<span class="status-pill status-active">active</span>`
        : `<span class="status-pill status-inactive">inactive</span>`
    }

    function applyGroupFilter() {
      const q = (document.getElementById("searchGroupInput").value || "").trim().toLowerCase()
      const filtered = allGroups.filter(item => {
        const text = `${item.groupId || ""} ${item.groupName || ""}`.toLowerCase()
        return !q || text.includes(q)
      })
      renderGroups(filtered)
    }

    function renderGroups(data) {
      const tbody = document.getElementById("groupTableBody")
      tbody.innerHTML = ""

      if (!data.length) {
        tbody.innerHTML = `<tr><td colspan="5" class="text-center text-muted py-4">ไม่พบกลุ่ม</td></tr>`
        return
      }

      data.forEach(item => {
        const safeItemJson = JSON.stringify(item).replace(/'/g, "\\'")
        const canDelete = isSuper
        const row = document.createElement("tr")
        row.innerHTML = `
          <td>${item.groupName || "-"}</td>
          <td>${item.groupId || "-"}</td>
          <td>${statusBadge(item.isActive)}</td>
          <td>${formatDateTime(item.lastSeenAt)}</td>
          <td>
            <div class="d-flex gap-2 flex-wrap">
              <button class="btn btn-outline-primary btn-sm" onclick='editGroup(${safeItemJson})'>แก้ไข</button>
              <button class="btn btn-outline-warning btn-sm" onclick="toggleGroup('${item._id}')">${item.isActive ? "ปิดใช้งาน" : "เปิดใช้งาน"}</button>
              ${canDelete ? `<button class="btn btn-outline-danger btn-sm" onclick="deleteGroup('${item._id}')">ลบ</button>` : ""}
            </div>
          </td>
        `
        tbody.appendChild(row)
      })
    }

    async function loadGroups() {
      try {
        const res = await fetch("/api/groups", {
          headers: { Authorization: `Bearer ${token}` }
        })
        const data = await res.json()
        if (!res.ok) {
          alert(data.error || "โหลดกลุ่มไม่สำเร็จ")
          return
        }
        allGroups = Array.isArray(data) ? data : []
        applyGroupFilter()
      } catch (error) {
        alert("โหลดกลุ่มไม่สำเร็จ")
      }
    }

    function editGroup(item) {
      document.getElementById("editGroupId").value = item._id || ""
      document.getElementById("groupId").value = item.groupId || ""
      document.getElementById("groupName").value = item.groupName || ""
      document.getElementById("isActive").value = String(Boolean(item.isActive))
      document.getElementById("groupId").disabled = true
      groupModal.show()
    }

    function resetGroupForm() {
      document.getElementById("editGroupId").value = ""
      document.getElementById("groupId").value = ""
      document.getElementById("groupName").value = ""
      document.getElementById("isActive").value = "false"
      document.getElementById("groupId").disabled = false
    }

    document.getElementById("groupForm").addEventListener("submit", async (e) => {
      e.preventDefault()

      const editGroupId = document.getElementById("editGroupId").value
      const groupId = document.getElementById("groupId").value
      const groupName = document.getElementById("groupName").value
      const isActive = document.getElementById("isActive").value === "true"

      const url = editGroupId ? `/api/groups/${editGroupId}` : "/api/groups"
      const method = editGroupId ? "PUT" : "POST"
      const payload = editGroupId ? { groupName, isActive } : { groupId, groupName, isActive }

      try {
        const res = await fetch(url, {
          method,
          headers: {
            "Content-Type": "application/json",
            Authorization: `Bearer ${token}`
          },
          body: JSON.stringify(payload)
        })
        const data = await res.json()
        if (!res.ok) {
          alert(data.error || "บันทึกกลุ่มไม่สำเร็จ")
          return
        }
        resetGroupForm()
        groupModal.hide()
        await loadGroups()
      } catch (error) {
        alert("บันทึกกลุ่มไม่สำเร็จ")
      }
    })

    async function toggleGroup(id) {
      try {
        const res = await fetch(`/api/groups/toggle/${id}`, {
          method: "PUT",
          headers: { Authorization: `Bearer ${token}` }
        })
        const data = await res.json()
        if (!res.ok) {
          alert(data.error || "เปลี่ยนสถานะกลุ่มไม่สำเร็จ")
          return
        }
        await loadGroups()
      } catch (error) {
        alert("เปลี่ยนสถานะกลุ่มไม่สำเร็จ")
      }
    }

    async function deleteGroup(id) {
      if (!confirm("ยืนยันการลบกลุ่มนี้?")) return
      try {
        const res = await fetch(`/api/groups/${id}`, {
          method: "DELETE",
          headers: { Authorization: `Bearer ${token}` }
        })
        const data = await res.json()
        if (!res.ok) {
          alert(data.error || "ลบกลุ่มไม่สำเร็จ")
          return
        }
        await loadGroups()
      } catch (error) {
        alert("ลบกลุ่มไม่สำเร็จ")
      }
    }

    document.addEventListener("DOMContentLoaded", async () => {
      groupModal = new bootstrap.Modal(document.getElementById("groupModal"))
      applyRoleVisibility()
      await loadGroups()
    })

    const socket = io()
    socket.on("connect", () => {
      document.getElementById("syncStatus").innerHTML = `<span class="sync-dot"></span> Realtime Sync`
    })
    socket.on("disconnect", () => {
      document.getElementById("syncStatus").innerHTML = `<span class="sync-dot" style="background:#dc2626;"></span> Sync Disconnected`
    })
    socket.on("dashboard:refresh", async () => {
      if (isRealtimeLoading) return
      isRealtimeLoading = true
      try {
        await loadGroups()
      } finally {
        setTimeout(() => { isRealtimeLoading = false }, 600)
      }
    })
  </script>
    <script src="/js/sidebarPolicy.js"></script>
    <script>
  initSidebarPolicy("groups")
    </script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>